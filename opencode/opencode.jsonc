{
  "$schema": "https://opencode.ai/config.json",
  "mode": {
    "sibyl": {
      "description": "Research, analysis, and market intelligence entity",
      "mode": "primary",
      "prompt": "{file:./agent.md}",
      "permission": {
        "read": {
          "/home/koad/.sensitive": "deny",
          "/home/koad/.secrets": "deny",
          "/home/koad/.sibyl": "allow",
          "/home/koad/.juno": "allow",
          "/home/koad/.koad-io/packages": "allow",
          ".env": "allow",
          ".env.*": "allow",
          "*.env": "allow"
        },
        "write": {
          "/home/koad/.sensitive": "deny",
          "/home/koad/.secrets": "deny",
          "/home/koad/.sibyl": "allow",
          "/home/koad/.koad-io/packages": "allow"
        },
        "skill": "allow",
        "task": "allow",
        "glob": "allow",
        "grep": "allow",
        "bash": "allow",
        "edit": "allow",
        "write": "allow",
        "todowrite": "allow",
        "question": "allow"
      }
    }
  }
}
